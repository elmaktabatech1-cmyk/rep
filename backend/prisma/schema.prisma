generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SALES
  ACCOUNTANT
  MARKETING
}

enum InventoryLogType {
  IN
  OUT
  RETURN
  ADJUSTMENT
}

enum OrderSource {
  WOOCOMMERCE
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentAccountType {
  CASH
  WALLET
  BANK
}

enum FinancialTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  EXPENSE_PAYMENT
}

enum CampaignStatus {
  DRAFT
  SENT
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum CouponType {
  PERCENT
  FIXED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(SALES)
  phone        String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inventoryLogs InventoryLog[]
  orders        Order[]        @relation("OrderCreatedBy")
  expenses      Expense[]
  salaries      Salary[]
  aiAuditLogs   AiAuditLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Customer {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  email            String?
  deviceModel      String?
  lastPurchaseDate DateTime?
  totalSpent       Decimal   @default(0) @db.Decimal(12, 2)
  loyaltyPoints    Int       @default(0)
  tags             Json      @default("[]")
  optInWhatsApp    Boolean   @default(true)
  optInEmail       Boolean   @default(true)
  referrerId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  referrer          Customer?  @relation("CustomerReferrals", fields: [referrerId], references: [id])
  referrals         Customer[] @relation("CustomerReferrals")
  orders            Order[]
  messageLogs       MessageLog[]
  referralsMade     Referral[] @relation("ReferrerRelation")
  referralsReceived Referral[] @relation("RefereeRelation")

  @@index([phone])
  @@index([email])
  @@index([referrerId])
  @@index([totalSpent])
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  category      String
  costPrice     Decimal  @db.Decimal(10, 2)
  sellPrice     Decimal  @db.Decimal(10, 2)
  stockQty      Int      @default(0)
  minStockAlert Int      @default(5)
  compatibility Json     @default("[]")
  warrantyMonths Int     @default(0)
  images        Json     @default("[]")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]

  @@index([sku])
  @@index([category])
  @@index([isActive])
}

model InventoryLog {
  id        String           @id @default(cuid())
  productId String
  type      InventoryLogType
  quantity  Int
  reason    String?
  userId    String?
  createdAt DateTime         @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([type])
}

model Order {
  id              String      @id @default(cuid())
  externalOrderId String?     @unique
  source          OrderSource @default(MANUAL)
  customerId      String?
  channel         String?
  status          OrderStatus @default(PENDING)
  paymentMethod   String?
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  rawPayload      Json?
  createdBy       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  creator    User?       @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  orderItems OrderItem[]
  invoice    Invoice?

  @@index([customerId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  quantity    Int
  priceAtSale Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String    @unique
  invoiceNumber String    @unique
  pdfUrl        String?
  sentVia       String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([invoiceNumber])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  taxNumber String?
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses Expense[]
}

model PaymentAccount {
  id             String             @id @default(cuid())
  name           String
  type           PaymentAccountType
  balance        Decimal            @default(0) @db.Decimal(12, 2)
  openingBalance Decimal            @default(0) @db.Decimal(12, 2)
  currency       String             @default("USD")
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())

  expenses                Expense[]
  transactions            FinancialTransaction[] @relation("AccountTransactions")
  destinationTransactions FinancialTransaction[] @relation("DestinationAccountTransactions")

  @@index([isActive])
}

model Expense {
  id               String   @id @default(cuid())
  category         String
  isFixed          Boolean  @default(false)
  amount           Decimal  @db.Decimal(12, 2)
  description      String?
  receiptUrl       String?
  date             DateTime
  supplierId       String?
  paymentAccountId String?
  createdBy        String?
  createdAt        DateTime @default(now())

  supplier       Supplier?              @relation(fields: [supplierId], references: [id])
  paymentAccount PaymentAccount?        @relation(fields: [paymentAccountId], references: [id])
  creator        User?                  @relation(fields: [createdBy], references: [id])
  transactions   FinancialTransaction[]

  @@index([category])
  @@index([date])
}

model FinancialTransaction {
  id                   String                   @id @default(cuid())
  type                 FinancialTransactionType
  amount               Decimal                  @db.Decimal(12, 2)
  description          String?
  accountId            String
  destinationAccountId String?
  expenseId            String?
  date                 DateTime
  createdAt            DateTime                 @default(now())

  account            PaymentAccount  @relation("AccountTransactions", fields: [accountId], references: [id])
  destinationAccount PaymentAccount? @relation("DestinationAccountTransactions", fields: [destinationAccountId], references: [id])
  expense            Expense?        @relation(fields: [expenseId], references: [id])

  @@index([accountId])
  @@index([type])
  @@index([date])
}

model Salary {
  id             String    @id @default(cuid())
  userId         String
  baseSalary     Decimal   @db.Decimal(10, 2)
  commissionRate Decimal   @default(0) @db.Decimal(5, 2)
  month          String
  paidAmount     Decimal   @default(0) @db.Decimal(10, 2)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([userId])
}

model Segment {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  filters       Json
  customerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  channel        MessageChannel
  segmentId      String?
  targetSegment  Json?
  status         CampaignStatus @default(DRAFT)
  sentCount      Int            @default(0)
  openedCount    Int            @default(0)
  clickedCount   Int            @default(0)
  convertedCount Int            @default(0)
  channelConfig  Json?
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())

  segment     Segment?     @relation(fields: [segmentId], references: [id])
  messageLogs MessageLog[]

  @@index([status])
  @@index([segmentId])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Decimal    @db.Decimal(10, 2)
  minPurchase Decimal    @default(0) @db.Decimal(10, 2)
  maxUses     Int?
  usedCount   Int        @default(0)
  expiresAt   DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([code])
  @@index([isActive])
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  refereeId    String
  couponCode   String?
  rewardAmount Decimal   @default(0) @db.Decimal(10, 2)
  used         Boolean   @default(false)
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  referrer Customer @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referee  Customer @relation("RefereeRelation", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
}

model MessageLog {
  id          String         @id @default(cuid())
  customerId  String?
  campaignId  String?
  channel     MessageChannel
  template    String?
  status      String
  apiResponse Json?
  sentAt      DateTime       @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([customerId])
  @@index([campaignId])
  @@index([status])
}

model WebhookLog {
  id           String    @id @default(cuid())
  source       String
  externalId   String?
  payload      Json
  status       String
  errorMessage String?   @db.Text
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model AiAuditLog {
  id           String   @id @default(cuid())
  userId       String?
  prompt       String   @db.Text
  actionsTaken Json?
  status       String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}
